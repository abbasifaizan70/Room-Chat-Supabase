# From Supabase: Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: exact URL OAuth should return to (must match Supabase → Authentication → Redirect URLs).
# If omitted, the app uses the current origin + Vite base path (see vite.config base / VITE_BASE_PATH).
# VITE_AUTH_REDIRECT_URL=http://localhost:5173/
